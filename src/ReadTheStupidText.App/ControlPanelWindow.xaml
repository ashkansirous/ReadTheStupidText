<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ReadTheStupidText_App.ControlPanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        The left-click control panel — the "Media Card" design (Decision 20): a
        brand-gradient "now reading" header (eyebrow, title, live waveform, status,
        transport row) over a Fluent settings list. Borderless, always-on-top, pinned
        (no click-away dismiss — see ControlPanelWindow.xaml.cs). Native WinUI controls
        + light/dark theme resources from design_handoff_tray_panel. Every control
        binds to the existing services; Quit stays in the right-click tray menu.
    -->
    <Grid x:Name="RootGrid" Background="Transparent" Width="376">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="PanelText" Color="#E3000000" />
                        <SolidColorBrush x:Key="PanelText2" Color="#8F000000" />
                        <SolidColorBrush x:Key="PanelText3" Color="#66000000" />
                        <SolidColorBrush x:Key="PanelStroke" Color="#14000000" />
                        <SolidColorBrush x:Key="PanelCard" Color="#99FFFFFF" />
                        <SolidColorBrush x:Key="PanelCBorder" Color="#1A000000" />
                        <SolidColorBrush x:Key="PanelAccent2" Color="#2A57C0" />
                        <SolidColorBrush x:Key="PanelKbd" Color="#0D000000" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="PanelText" Color="#EBFFFFFF" />
                        <SolidColorBrush x:Key="PanelText2" Color="#94FFFFFF" />
                        <SolidColorBrush x:Key="PanelText3" Color="#66FFFFFF" />
                        <SolidColorBrush x:Key="PanelStroke" Color="#14FFFFFF" />
                        <SolidColorBrush x:Key="PanelCard" Color="#0BFFFFFF" />
                        <SolidColorBrush x:Key="PanelCBorder" Color="#1AFFFFFF" />
                        <SolidColorBrush x:Key="PanelAccent2" Color="#9CBEFF" />
                        <SolidColorBrush x:Key="PanelKbd" Color="#14FFFFFF" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>

                <!-- Brand gradient (header + brand mark), identical in both themes. -->
                <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5B57E8" Offset="0" />
                    <GradientStop Color="#3B82F6" Offset="1" />
                </LinearGradientBrush>

                <!-- Translucent whites used on top of the gradient header. -->
                <SolidColorBrush x:Key="HeaderText" Color="#EBFFFFFF" />
                <SolidColorBrush x:Key="HeaderEyebrow" Color="#B3FFFFFF" />
                <SolidColorBrush x:Key="HeaderWave" Color="#E6FFFFFF" />
                <SolidColorBrush x:Key="HeaderControl" Color="#33FFFFFF" />
                <SolidColorBrush x:Key="HeaderTrack" Color="#4DFFFFFF" />

                <!-- The animated 5-bar waveform; runs only while reading. -->
                <Storyboard x:Key="WaveformStoryboard" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="WaveScale1" Storyboard.TargetProperty="ScaleY"
                        From="0.5" To="1.3" Duration="0:0:0.45" />
                    <DoubleAnimation Storyboard.TargetName="WaveScale2" Storyboard.TargetProperty="ScaleY"
                        From="1.2" To="0.6" Duration="0:0:0.55" />
                    <DoubleAnimation Storyboard.TargetName="WaveScale3" Storyboard.TargetProperty="ScaleY"
                        From="0.7" To="1.4" Duration="0:0:0.38" />
                    <DoubleAnimation Storyboard.TargetName="WaveScale4" Storyboard.TargetProperty="ScaleY"
                        From="1.3" To="0.7" Duration="0:0:0.5" />
                    <DoubleAnimation Storyboard.TargetName="WaveScale5" Storyboard.TargetProperty="ScaleY"
                        From="0.6" To="1.2" Duration="0:0:0.6" />
                </Storyboard>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ============ Gradient header ============ -->
        <!-- Border clips the rotated watermark that overflows its bounds. -->
        <Border Grid.Row="0" Background="{StaticResource BrandGradient}">
            <Grid Padding="16,14,16,16">
                <!-- Glyph watermark, top-right, rotated and faint. -->
                <Image
                    Source="ms-appx:///Assets/Logotype Glyph.png"
                    Width="120"
                    Height="120"
                    Opacity="0.13"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-12,-14,0">
                    <Image.RenderTransform>
                        <RotateTransform Angle="-8" CenterX="60" CenterY="60" />
                    </Image.RenderTransform>
                </Image>

                <StackPanel>
                    <!-- Title row: eyebrow + title (left), close (right) -->
                    <Grid>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                Text="NOW READING"
                                FontSize="10"
                                FontWeight="Bold"
                                CharacterSpacing="180"
                                Foreground="{StaticResource HeaderEyebrow}" />
                            <TextBlock
                                Text="Read The Stupid Text"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Margin="0,2,0,0"
                                Foreground="{StaticResource HeaderText}" />
                        </StackPanel>
                        <Button
                            x:Name="CloseButton"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Width="28"
                            Height="28"
                            Padding="0"
                            CornerRadius="5"
                            Background="{StaticResource HeaderControl}"
                            BorderThickness="0"
                            Foreground="{StaticResource HeaderText}"
                            Click="OnCloseClick"
                            ToolTipService.ToolTip="Close">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE711;" FontSize="11" />
                        </Button>
                    </Grid>

                    <!-- Status row: waveform + dynamic status text -->
                    <StackPanel Orientation="Horizontal" Spacing="9" Margin="0,13,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="3" Height="18" VerticalAlignment="Bottom">
                            <Rectangle Width="3" Height="9" RadiusX="2" RadiusY="2" Fill="{StaticResource HeaderWave}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1">
                                <Rectangle.RenderTransform><ScaleTransform x:Name="WaveScale1" /></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Width="3" Height="15" RadiusX="2" RadiusY="2" Fill="{StaticResource HeaderWave}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1">
                                <Rectangle.RenderTransform><ScaleTransform x:Name="WaveScale2" /></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Width="3" Height="7" RadiusX="2" RadiusY="2" Fill="{StaticResource HeaderWave}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1">
                                <Rectangle.RenderTransform><ScaleTransform x:Name="WaveScale3" /></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Width="3" Height="18" RadiusX="2" RadiusY="2" Fill="{StaticResource HeaderWave}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1">
                                <Rectangle.RenderTransform><ScaleTransform x:Name="WaveScale4" /></Rectangle.RenderTransform>
                            </Rectangle>
                            <Rectangle Width="3" Height="11" RadiusX="2" RadiusY="2" Fill="{StaticResource HeaderWave}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1">
                                <Rectangle.RenderTransform><ScaleTransform x:Name="WaveScale5" /></Rectangle.RenderTransform>
                            </Rectangle>
                        </StackPanel>
                        <TextBlock
                            x:Name="StatusText"
                            Text="Ready"
                            FontSize="12.5"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Foreground="{StaticResource HeaderText}" />
                    </StackPanel>

                    <!-- Transport row: play/pause + progress + speed pill -->
                    <Grid Margin="0,15,0,0" ColumnSpacing="12" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            x:Name="PlayPauseButton"
                            Grid.Column="0"
                            Width="40"
                            Height="40"
                            Padding="0"
                            CornerRadius="20"
                            Background="{StaticResource HeaderControl}"
                            BorderThickness="0"
                            Foreground="{StaticResource HeaderText}"
                            Click="OnPlayPauseClick">
                            <FontIcon x:Name="PlayPauseIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE768;" FontSize="15" />
                        </Button>

                        <!-- Display-only read-through progress (fill columns weighted
                             by progress; thumb sits at the boundary). Seek is
                             best-effort / out of scope — see Decision 21. -->
                        <Grid Grid.Column="1" Height="16" VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{StaticResource HeaderTrack}" VerticalAlignment="Center" />
                            <Grid VerticalAlignment="Center" Height="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ProgressFillColumn" Width="0*" />
                                    <ColumnDefinition x:Name="ProgressRestColumn" Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Height="4" CornerRadius="2" Background="{StaticResource HeaderText}" VerticalAlignment="Center" />
                                <Ellipse Grid.Column="0" Width="16" Height="16" Fill="{StaticResource HeaderText}" HorizontalAlignment="Right">
                                    <Ellipse.RenderTransform><TranslateTransform X="8" /></Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                        </Grid>

                        <Border Grid.Column="2" Background="{StaticResource HeaderControl}" CornerRadius="11" Padding="9,3">
                            <TextBlock x:Name="SpeedPill" Text="1×" FontSize="12" FontWeight="Bold" Foreground="{StaticResource HeaderText}" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ============ Settings list ============ -->
        <StackPanel Grid.Row="1" Padding="8,6,8,8">
            <!-- Speed (fine 0.05 slider — Decision 13) -->
            <Grid Padding="10,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{ThemeResource PanelCard}" BorderThickness="1" BorderBrush="{ThemeResource PanelStroke}" VerticalAlignment="Top">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE916;" FontSize="15" Foreground="{ThemeResource PanelAccent2}" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <Grid>
                        <TextBlock Text="Speed" FontSize="13" Foreground="{ThemeResource PanelText}" VerticalAlignment="Center" />
                        <TextBlock x:Name="SpeedLabel" HorizontalAlignment="Right" FontSize="11.5" Foreground="{ThemeResource PanelText2}" VerticalAlignment="Center" />
                    </Grid>
                    <Slider
                        x:Name="SpeedSlider"
                        Minimum="0.5"
                        Maximum="2.0"
                        StepFrequency="0.05"
                        SnapsTo="StepValues"
                        Margin="0,-4,0,-8"
                        ValueChanged="OnSpeedSliderChanged" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{ThemeResource PanelStroke}" Margin="10,0" />

            <!-- Voice (neural). Shows a preparing state until the model loads. -->
            <Grid Padding="10,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{ThemeResource PanelCard}" BorderThickness="1" BorderBrush="{ThemeResource PanelStroke}" VerticalAlignment="Top">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE767;" FontSize="15" Foreground="{ThemeResource PanelAccent2}" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Voice" FontSize="13" Foreground="{ThemeResource PanelText}" />
                    <ComboBox
                        x:Name="VoiceCombo"
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="DisplayName"
                        SelectionChanged="OnVoiceSelectionChanged" />
                    <TextBlock
                        x:Name="VoiceStatus"
                        Text="Preparing neural voice…"
                        Visibility="Collapsed"
                        FontSize="11.5"
                        Foreground="{ThemeResource PanelText2}" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{ThemeResource PanelStroke}" Margin="10,0" />

            <!-- Auto-read on selection -->
            <Grid Padding="10,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{ThemeResource PanelCard}" BorderThickness="1" BorderBrush="{ThemeResource PanelStroke}">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8B3;" FontSize="15" Foreground="{ThemeResource PanelAccent2}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Auto-read on selection" FontSize="13" Foreground="{ThemeResource PanelText}" />
                    <TextBlock Text="Reads aloud as you select" FontSize="11.5" Foreground="{ThemeResource PanelText2}" />
                </StackPanel>
                <ToggleSwitch x:Name="AutoReadSelectionSwitch" Grid.Column="2" MinWidth="0" OnContent="" OffContent="" Toggled="OnAutoReadSelectionToggled" />
            </Grid>

            <Border Height="1" Background="{ThemeResource PanelStroke}" Margin="10,0" />

            <!-- Auto-read on copy -->
            <Grid Padding="10,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{ThemeResource PanelCard}" BorderThickness="1" BorderBrush="{ThemeResource PanelStroke}">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8C8;" FontSize="15" Foreground="{ThemeResource PanelAccent2}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Auto-read on copy" FontSize="13" Foreground="{ThemeResource PanelText}" />
                    <TextBlock Text="Reads aloud when you copy (console)" FontSize="11.5" Foreground="{ThemeResource PanelText2}" />
                </StackPanel>
                <ToggleSwitch x:Name="AutoReadCopySwitch" Grid.Column="2" MinWidth="0" OnContent="" OffContent="" Toggled="OnAutoReadCopyToggled" />
            </Grid>

            <Border Height="1" Background="{ThemeResource PanelStroke}" Margin="10,0" />

            <!-- Launch at startup -->
            <Grid Padding="10,8" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{ThemeResource PanelCard}" BorderThickness="1" BorderBrush="{ThemeResource PanelStroke}">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7E8;" FontSize="15" Foreground="{ThemeResource PanelAccent2}" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Launch at startup" FontSize="13" Foreground="{ThemeResource PanelText}" />
                    <TextBlock Text="Start with Windows, in the tray" FontSize="11.5" Foreground="{ThemeResource PanelText2}" />
                </StackPanel>
                <ToggleSwitch x:Name="StartupSwitch" Grid.Column="2" MinWidth="0" OnContent="" OffContent="" Toggled="OnStartupToggled" />
            </Grid>

            <!-- Hotkey footer -->
            <Grid Padding="10,8,10,4">
                <TextBlock Text="Hotkey fallback" FontSize="11" Foreground="{ThemeResource PanelText2}" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="{ThemeResource PanelKbd}" BorderBrush="{ThemeResource PanelCBorder}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Ctrl" FontSize="11" Foreground="{ThemeResource PanelText}" />
                    </Border>
                    <TextBlock Text="+" FontSize="11" Foreground="{ThemeResource PanelText3}" VerticalAlignment="Center" />
                    <Border Background="{ThemeResource PanelKbd}" BorderBrush="{ThemeResource PanelCBorder}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="Win" FontSize="11" Foreground="{ThemeResource PanelText}" />
                    </Border>
                    <TextBlock Text="+" FontSize="11" Foreground="{ThemeResource PanelText3}" VerticalAlignment="Center" />
                    <Border Background="{ThemeResource PanelKbd}" BorderBrush="{ThemeResource PanelCBorder}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                        <TextBlock Text="R" FontSize="11" Foreground="{ThemeResource PanelText}" />
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
