<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ReadTheStupidText_App.ActivityLogWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ReadTheStupidText_App"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        A normal, resizable diagnostic window (appears in the taskbar/alt-tab,
        unlike the pinned control panel) showing read activity live. Rows are
        ActivityRowVm; the entry State updates the row in place. See Slice 10.
    -->
    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Brand-gradient header — mirrors the control panel's eyebrow + title
             treatment so the diagnostic window reads as the same product. -->
        <Border Grid.Row="0" Background="{StaticResource BrandGradient}">
            <Grid Padding="16,12" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- The app tile, rounded — the brand mark on the gradient. -->
                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="8" VerticalAlignment="Center">
                    <Border.Background>
                        <ImageBrush ImageSource="ms-appx:///Assets/Square150x150Logo.scale-200.png" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock
                        Text="READ THE STUPID TEXT"
                        FontSize="10"
                        FontWeight="Bold"
                        CharacterSpacing="180"
                        Foreground="{StaticResource HeaderEyebrow}" />
                    <TextBlock
                        Text="Activity log"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Margin="0,2,0,0"
                        Foreground="{StaticResource HeaderText}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button
                        Content="Open logs"
                        Click="OnOpenLogsClick"
                        ToolTipService.ToolTip="Open the daily log files folder"
                        Padding="14,6"
                        CornerRadius="6"
                        Background="{StaticResource HeaderControl}"
                        BorderThickness="0"
                        Foreground="{StaticResource HeaderText}" />
                    <Button
                        Content="Clear"
                        Click="OnClearClick"
                        Padding="14,6"
                        CornerRadius="6"
                        Background="{StaticResource HeaderControl}"
                        BorderThickness="0"
                        Foreground="{StaticResource HeaderText}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Column headings -->
        <Grid Grid.Row="1" Padding="12,4" ColumnSpacing="12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="52" />
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="108" />
                <ColumnDefinition Width="84" />
                <ColumnDefinition Width="74" />
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Time" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="1" Text="Trigger" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="2" Text="State" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="3" Text="Reason" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="4" Text="First audio" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="5" Text="Synth" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="6" Text="Source" Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock Grid.Column="7" Text="Text" Style="{ThemeResource CaptionTextBlockStyle}" />
        </Grid>

        <ListView
            x:Name="LogList"
            Grid.Row="2"
            ItemsSource="{x:Bind Rows}"
            SelectionMode="None">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ActivityRowVm">
                    <Grid Padding="12,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="74" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind Time}" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Trigger}" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="{x:Bind State, Mode=OneWay}" />
                        <TextBlock
                            Grid.Column="3"
                            Text="{x:Bind Reason, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="4"
                            Text="{x:Bind FirstAudio, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock
                            Grid.Column="5"
                            Text="{x:Bind Synth, Mode=OneWay}"
                            Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBlock
                            Grid.Column="6"
                            Text="{x:Bind Source}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="{x:Bind Source}" />
                        <TextBlock Grid.Column="7" Text="{x:Bind Text}" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
